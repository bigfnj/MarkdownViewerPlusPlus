{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-x64",
      "displayName": "Visual Studio 2026 x64",
      "description": "Generate a VS2026 solution for the native Markdown++ plugin.",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/cmake/vs2026-x64",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/install/vs2026-x64",
        "MARKDOWNPP_BUILD_NATIVE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-debug",
      "displayName": "VS2026 Debug",
      "configurePreset": "vs2026-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-release",
      "displayName": "VS2026 Release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release"
    },
    {
      "name": "vs2026-package-release",
      "displayName": "VS2026 Package Release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release",
      "targets": [
        "markdownplusplus_package"
      ]
    }
  ]
}
